<div class="container-fluid mt-4">
  
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <h3 class="mb-0">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Driver Details</h3>

    <!-- Search Bar -->
    <div class="search-box" style="min-width: 300px;">
      <form id="searchForm" class="d-flex gap-2">
        <input 
          type="text" 
          id="driverSearch" 
          name="search"
          placeholder="Search by name, phone..."
          class="form-control"
          value="<%= pagination.searchQuery || '' %>"
        >
        <button type="submit" class="btn btn-dark">Search</button>
        <% if (pagination.searchQuery) { %>
          <a href="/admin/drivers" class="btn btn-secondary">Clear</a>
        <% } %>
      </form>
    </div>
  </div>

  <div class="trip-cards" id="tripCards">
    <!-- Cards injected by JS -->
  </div>
</div>
<%- include("../layouts/adminheaders") %> <%- include("../layouts/sidebar") %>
    <link rel="stylesheet" href="/css/drivers.css">
    <div class="container-fluid mt-4 ml-5">
      <!-- <h3 class="mb-4">Drivers List</h3> -->

      <div class="card">
        <div class="card-body">
          <table class="table table-bordered table-hover">
            <thead class="table-dark">
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Phone</th>
                <th>Verified</th>
                <th>Joined</th>
                <th>Action</th>
              </tr>
            </thead>
            <% console.log(data,"datadata") %>
              <tbody>
                <% if (data.length===0) { %>
                  <tr>
                    <td colspan="6" class="text-center">No drivers found</td>
                  </tr>
                  <% } %>
                    <% data.forEach((driver, index)=> { %>
                      <tr>
                        <td>
                          <%= index + 1 %>
                        </td>
                        <td>
                          <%= driver.name %>
                        </td>
                        <td>
                          <%= driver.phone %>
                        </td>
                        <td>
                          <% if (driver.isApproved) { %>
                            <span class="badge bg-success">Approved</span>
                            <% } else { %>
                              <span class="badge bg-danger text-dark">Not Approved</span>
                              <% } %>
                        </td>
                        <td>
                          <%= new Date(driver.createdAt).toLocaleDateString() %>
                        </td>
                        <td>
                          <button class="btn btn-sm btn-info add-payment-btn" data-bs-toggle="modal"
                            data-bs-target="#addPaymentModal" data-driver-id="<%= driver._id %>">
                            Add Payment
                          </button>
                          <button class="btn btn-sm btn-info deduct-payment-btn" data-bs-toggle="modal"
                            data-bs-target="#deductPaymentModal" data-driver-id="<%= driver._id %>">
                            Deduct Payment
                          </button>
                          <button class="btn btn-sm btn-info approve-driver-btn" data-driver-id="<%= driver._id %>" data-approved="<%= driver.isApproved %>">
                            <%= driver.isApproved ? 'Disapprove' : 'Approve' %>
                          </button>
                          <button class="btn btn-sm btn-info view-driver-btn" data-bs-toggle="modal"
                            data-bs-target="#driverDetailsModal" data-driver-id="<%= driver._id %>">
                            View
                          </button>
                        </td>
                      </tr>
                      <% }) %>
              </tbody>
          </table>

          <% if (pagination.totalPages> 1) { %>
            <nav>
              <ul class="pagination justify-content-center">

                <% if (pagination.page> 1) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= pagination.page - 1 %><%= pagination.searchQuery ? '&search=' + encodeURIComponent(pagination.searchQuery) : '' %>">Prev</a>
                  </li>
                  <% } %>

                    <% for (let i=1; i <=pagination.totalPages; i++) { %>
                      <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                        <a class="page-link" href="?page=<%= i %><%= pagination.searchQuery ? '&search=' + encodeURIComponent(pagination.searchQuery) : '' %>">
                          <%= i %>
                        </a>
                      </li>
                      <% } %>

                        <% if (pagination.page < pagination.totalPages) { %>
                          <li class="page-item">
                            <a class="page-link" href="?page=<%= pagination.page + 1 %><%= pagination.searchQuery ? '&search=' + encodeURIComponent(pagination.searchQuery) : '' %>">Next</a>
                          </li>
                          <% } %>

              </ul>
            </nav>
            <% } %>

        </div>
      </div>
    </div>

    <!-- modal -->
    <!-- Add Payment Modal -->
    <div class="modal fade" id="addPaymentModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

          <div class="modal-header">
            <h5 class="modal-title">Add Payment</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <form>
            <div class="modal-body">

              <!-- Hidden Driver ID -->
              <input type="hidden" name="driverId" id="addPaymentDriverId">

              <div class="mb-3">
                <label class="form-label">Amount</label>
                <input type="number" id="addAmount" name="addAmount" class="form-control" required min="1" />
              </div>

            </div>

            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                Cancel
              </button>
              <button type="button" class="btn btn-success" onclick="addPayment()">
                Add
              </button>
            </div>
          </form>

        </div>
      </div>
    </div>

    <!-- deduct modal -->
    <div class="modal fade" id="deductPaymentModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

          <div class="modal-header">
            <h5 class="modal-title">Deduct Payment</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <form>
            <div class="modal-body">

              <!-- Hidden Driver ID -->
              <input type="hidden" name="driverId" id="deductPaymentDriverId">

              <div class="mb-3">
                <label class="form-label">Amount</label>
                <input type="number" id="deductAmount" name="deductAmount" class="form-control" required min="1" />
              </div>

            </div>

            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                Cancel
              </button>
              <button type="button" class="btn btn-success" onclick="deductPayment()">
                Deduct
              </button>
            </div>
          </form>

        </div>
      </div>
    </div>

<!-- Driver Details Modal -->
    <div class="modal fade" id="driverDetailsModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">

          <div class="modal-header">
            <h5 class="modal-title">Driver Details</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <div class="modal-body">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="fw-bold">Name:</label>
                <p id="detailsName"></p>
              </div>
              <div class="col-md-6 mb-3">
                <label class="fw-bold">Phone:</label>
                <p id="detailsPhone"></p>
              </div>
              <div class="col-md-6 mb-3">
                <label class="fw-bold">Verification Status:</label>
                <p id="detailsVerified"></p>
              </div>
              <div class="col-md-6 mb-3">
                <label class="fw-bold">Joined Date:</label>
                <p id="detailsJoinedDate"></p>
              </div>
              <div class="col-md-6 mb-3">
                <label class="fw-bold">aadhaar:</label>
                <img id="detailsAadhaar" src="" alt="Aadhaar" style="max-width: 100%; max-height: 200px; object-fit: contain;">
              </div>
              <div class="col-md-6 mb-3">
                <label class="fw-bold">Car Image:</label>
                <img id="detailsCarImage" src="" alt="Car Image" style="max-width: 100%; max-height: 200px; object-fit: contain;">
              </div>
              <div class="col-md-6 mb-3">
                <label class="fw-bold">License:</label>
                <img id="detailsLicense" src="" alt="License" style="max-width: 100%; max-height: 200px; object-fit: contain;">
              </div>
              <div class="col-md-6 mb-3">
                <label class="fw-bold">Insurance:</label>
                <img id="detailsInsurance" src="" alt="Insurance" style="max-width: 100%; max-height: 200px; object-fit: contain;">
              </div>
                <div class="col-md-6 mb-3">
                <label class="fw-bold">Register Certificate:</label>
                <img id="detailsRegisterCertificate" src="" alt="Register Certificate" style="max-width: 100%; max-height: 200px; object-fit: contain;">
              </div>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
              Close
            </button>
          </div>

        </div>
      </div>
    </div>

    
    <script>
      // Handle search form submission
      document.getElementById("searchForm").addEventListener("submit", (e) => {
        e.preventDefault();
        const searchQuery = document.getElementById("driverSearch").value.trim();
        if (searchQuery) {
          window.location.href = `/admin/drivers?search=${encodeURIComponent(searchQuery)}`;
        } else {
          window.location.href = `/admin/drivers`;
        }
      });

      document.addEventListener("DOMContentLoaded", () => {

        document.querySelectorAll(".add-payment-btn").forEach(btn => {
          btn.addEventListener("click", () => {
            document.getElementById("addPaymentDriverId").value =
              btn.dataset.driverId;
          });
        });

        document.querySelectorAll(".deduct-payment-btn").forEach(btn => {
          btn.addEventListener("click", () => {
            document.getElementById("deductPaymentDriverId").value =
              btn.dataset.driverId;
          });
        });

        document.querySelectorAll(".view-driver-btn").forEach(btn => {
          btn.addEventListener("click", () => {
            const driverId = btn.dataset.driverId;
            populateDriverDetails(driverId);
          });
        });

        document.querySelectorAll(".approve-driver-btn").forEach(btn => {
          btn.addEventListener("click", () => {
            console.log("btn.dataset",btn.dataset);
            
            const driverId = btn.dataset.driverId;
            const isApproved = btn.dataset.approved === 'true';
            const action = isApproved ? 'disapprove' : 'approve';
            approveDriver(driverId, action);
          });
        });

      });

      function populateDriverDetails(driverId) {
        // Find driver in the data
        const drivers = <%- JSON.stringify(data) %>;
        const driver = drivers.find(d => d._id === driverId);
        if (driver) {
          document.getElementById("detailsName").textContent = driver.name || "N/A";
          document.getElementById("detailsPhone").textContent = driver.phone || "N/A";
          document.getElementById("detailsVerified").innerHTML = driver.isApproved
            ? '<span class="badge bg-success">Approved</span>' 
            : '<span class="badge bg-warning text-dark">Pending</span>';
          document.getElementById("detailsJoinedDate").textContent = driver.createdAt 
            ? new Date(driver.createdAt).toLocaleDateString() 
            : "N/A";
          document.getElementById("detailsLicense").src = driver.Documents?.[0]?.license || "";
          document.getElementById("detailsAadhaar").src = driver.Documents?.[0]?.aadhaar || "";
          document.getElementById("detailsCarImage").src = driver.Documents?.[0]?.car_photo || "";
          document.getElementById("detailsInsurance").src = driver.Documents?.[0]?.insurance || "";
          document.getElementById("detailsRegisterCertificate").src = driver.Documents?.[0]?.register_certificate || "";

        }
      }

      async function addPayment() {
        const driverId = document.getElementById("addPaymentDriverId").value;
        const amount = document.getElementById("addAmount").value;

        try {
          const res = await fetch("/admin/transactions/add-payment", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ driverId, amount }),
          });

          const data = await res.json();
          if (!res.ok) {
            showToast(data.message, "error");
            return;
          }
          showToast(data.message, "success");
          location.reload();
        } catch (err) {
          showToast("Network error", "error");
        }
      };

      async function deductPayment() {
        const driverId = document.getElementById("deductPaymentDriverId").value;
        const amount = document.getElementById("deductAmount").value;

        try {
          const res = await fetch("/admin/transactions/deduct-payment", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ driverId, amount }),
          });

          const data = await res.json();

          if (!res.ok) {
            showToast(data.message, "error");
            return;
          }

          showToast(data.message, "success");
          location.reload();

        } catch (err) {
          showToast("Network error", "error");
        }
      };

      async function approveDriver(driverId, action) {
        const endpoint = action === 'approve' ? '/admin/drivers/approve' : '/admin/drivers/disapprove';
        const actionText = action === 'approve' ? 'approved' : 'disapproved';

        try {
          const res = await fetch(endpoint, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ driverId }),
          });

          const data = await res.json();

          if (!res.ok) {
            showToast(data.message, "error");
            return;
          }

          showToast(`Driver ${actionText} successfully`, "success");
          location.reload();

        } catch (err) {
          console.error(err);
          showToast("Network error", "error");
        }
      };

      function showToast(message, type = "success") {
        alert(`${type.toUpperCase()}: ${message}`);
      }

    </script>


    <%- include("../layouts/adminfooter") %>