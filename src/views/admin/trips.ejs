<%- include("../layouts/adminheaders") %>
  <link rel="stylesheet" href="/css/trip.css">

  <div class="container-fluid mt-4">
  
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <h3 class="mb-0">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp Trip Details</h3>

    <!-- Search Bar -->
    <div class="search-box" style="min-width: 300px;">
      <form id="searchForm" class="d-flex gap-2">
        <input 
          type="text" 
          id="tripSearch" 
          name="search"
          placeholder="Search Trip Details..."
          class="form-control"
          value="<%= pagination.searchQuery || '' %>"
        >
        <button type="submit" class="btn btn-dark">Search</button>
        <% if (pagination.searchQuery) { %>
          <a href="/admin/trips" class="btn btn-secondary">Clear</a>
        <% } %>
      </form>
    </div>
  </div>

  <div class="admin-layout">
    <%- include("../layouts/sidebar") %>

      <main class="tripcontent-area">
        <div class="container-fluid mt-4">
        
          <div class="trip-cards" id="tripCards">
            <% if (data.length === 0) { %>
              <p class="text-center">No trips found</p>
            <% } %>

            <% data.forEach((trip, index) => { %>
              <% 
                const drivers = (trip.driverId || []).slice(0, 3).map((d) => ({
                  name: d.name,
                  _id: d._id,
                }));

                while (drivers.length < 3) {
                  drivers.push({ name: "—", _id: null });
                }
              %>
              <div class="trip-card">
                <div class="trip-card-header">
                  <span class="trip-id">#<%= index + 1 %></span>
                  <span class="status <%= trip.status %>">
                    <%= trip.status %>
                  </span>
                </div>

                <div class="trip-info">
                  <p><strong>Date:</strong> <%= new Date(trip.createdAt).toLocaleString() %></p>
                  <p><strong>Booking ID:</strong> <%= trip.bookingId?._id || trip._id %></p>
                  <p><strong>Pickup:</strong> <%= trip.bookingId?.pickup || "-" %></p>
                  <p><strong>Drop:</strong> <%= trip.bookingId?.drop || "-" %></p>
                </div>

                <div class="trip-drivers">
                  <% drivers.forEach(driver => { %>
                    <div class="driver-row">
                      <span><%= driver.name %></span>
                      <button class="btn-assign"
                        <%= driver.name === "—" || trip.status === "Closed" ? "disabled" : "" %>
                        onclick="assignDriver('<%= trip._id %>', '<%= driver._id %>') ">
                        Assign
                      </button>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <nav>
              <ul class="pagination justify-content-center mt-4">
                <% if (pagination.page > 1) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= pagination.page - 1 %><%= pagination.searchQuery ? '&search=' + encodeURIComponent(pagination.searchQuery) : '' %>">Prev</a>
                  </li>
                <% } %>

                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                  <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %><%= pagination.searchQuery ? '&search=' + encodeURIComponent(pagination.searchQuery) : '' %>">
                      <%= i %>
                    </a>
                  </li>
                <% } %>

                <% if (pagination.page < pagination.totalPages) { %>
                  <li class="page-item">
                    <a class="page-link" href="?page=<%= pagination.page + 1 %><%= pagination.searchQuery ? '&search=' + encodeURIComponent(pagination.searchQuery) : '' %>">Next</a>
                  </li>
                <% } %>
              </ul>
            </nav>
          <% } %>
        </div>
      </main>
  </div>


  <%- include("../layouts/adminfooter") %>
    <script>
      // Handle search form submission
      document.getElementById("searchForm").addEventListener("submit", (e) => {
        e.preventDefault();
        const searchQuery = document.getElementById("tripSearch").value.trim();
        if (searchQuery) {
          window.location.href = `/admin/trips?search=${encodeURIComponent(searchQuery)}`;
        } else {
          window.location.href = `/admin/trips`;
        }
      });

      async function assignDriver(tripId, driverId) {
        if (!driverId || driverId === "—" || driverId == "null") {
          alert("Invalid driver");
          return;
        }

        if (!confirm("Are you sure you want to assign this driver?")) return;

        try {
          const response = await fetch("/admin/bookings/assign", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            credentials: "include",
            body: JSON.stringify({ tripId, driverId }),
          });

          const result = await response.json();

          if (!result.status) {
            alert(result.message || "Failed to assign driver");
            return;
          }

          alert("Driver assigned successfully");

          // Reload page or re-fetch trips
          location.reload();
        } catch (error) {
          console.error("Assign error:", error);
          alert("Something went wrong");
        }
      } 
    </script>
